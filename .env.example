# StackSmart Environment Variables
# Copy to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StackSmart

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Supabase Postgres)
DATABASE_URL=your-database-url

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (TEST MODE ONLY)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_stacksmart_placeholder
STRIPE_SECRET_KEY=sk_test_stacksmart_placeholder
STRIPE_WEBHOOK_SECRET=whsec_stacksmart_placeholder

# Email (Resend)
RESEND_API_KEY=re_stacksmart_placeholder
EMAIL_FROM=StackSmart <onboarding@resend.dev>

# Auth
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
